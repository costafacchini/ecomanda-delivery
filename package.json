{
  "name": "ecomanda-delivery",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "author": "Alan Costa Facchini",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "start": "node server.js",
    "build": "cd client && yarn && yarn run build",
    "dev": "npm-run-all -p dev:*",
    "dev:server": "bash -c 'docker compose up -d && trap \"docker compose stop\" SIGINT && nodemon server.js'",
    "dev:worker": "nodemon worker.js",
    "test": "NODE_ENV=test jest --config=jest.config.mjs --no-coverage --maxWorkers=50%",
    "test:ci": "NODE_ENV=test jest --config=jest.config.mjs",
    "test:coverage": "NODE_ENV=test jest --config=jest.config.mjs --maxWorkers=50%",
    "watch": "NODE_ENV=test jest --no-coverage --verbose --watch --runInBand --notify --notifyMode always",
    "linter": "yarn eslint 'src/app/**/*.{js,ts,tsx}' 'src/config/**/*.{js,ts,tsx}' 'src/setup/**/*.{js,ts,tsx}'"
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/plugin-transform-modules-commonjs": "^7.27.1",
    "@babel/preset-env": "^7.28.3",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/utils": "^8.58.0",
    "babel-jest": "^30.2.0",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-config-standard": "17.1.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jest": "29.15.2",
    "eslint-plugin-jest-dom": "5.5.0",
    "eslint-plugin-n": "17.24.0",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-promise": "7.2.1",
    "jest": "30.3.0",
    "jest-date-mock": "1.0.10",
    "mongodb-memory-server": "11.0.1",
    "mongodb-memory-server-global": "11.0.1",
    "npm-run-all2": "8.0.4",
    "prettier": "3.8.3",
    "supertest": "7.2.2"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.32.0",
    "@aws-sdk/s3-request-presigner": "^3.32.0",
    "@bull-board/api": "^6.12.0",
    "@bull-board/express": "^6.12.0",
    "@bull-board/ui": "^6.12.0",
    "@sentry/node": "^10.25.0",
    "amqplib": "1.0.3",
    "archiver": "7.0.1",
    "bcrypt": "6.0.0",
    "bl": "^6.0.7",
    "bullmq": "5.75.2",
    "cors": "2.8.6",
    "debug": "4.4.3",
    "dotenv": "17.4.2",
    "esm-module-alias": "^2.2.1",
    "express": "5.2.1",
    "express-validator": "7.3.2",
    "fishery": "2.4.0",
    "http-errors": "2.0.1",
    "isomorphic-fetch": "3.0.0",
    "jsonwebtoken": "9.0.3",
    "lodash": "4.18.1",
    "module-alias": "2.3.4",
    "moment": "2.30.1",
    "moment-timezone": "0.6.1",
    "mongodb": "7.1.1",
    "mongoose": "9.5.0",
    "morgan": "1.10.1",
    "newrelic": "13.18.0",
    "node-notifier": "10.0.1",
    "nodemon": "3.1.14",
    "rollbar": "3.1.0",
    "socket.io": "4.8.3",
    "uuid": "13.0.0",
    "yarn": "1.22.22"
  },
  "_moduleAliases": {
    "@models": "./src/app/models",
    "@controllers": "./src/app/controllers",
    "@routes": "./src/app/routes",
    "@config": "./src/config",
    "@queries": "./src/app/queries",
    "@reports": "./src/app/reports",
    "@helpers": "./src/app/helpers",
    "@plugins": "./src/app/plugins",
    "@repositories": "./src/app/repositories"
  },
  "resolutions": {
    "lodash": "4.18.1",
    "@typescript-eslint/utils": "^8.58.0"
  }
}
