{
  "name": "ecomanda-delivery",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "author": "Alan Costa Facchini",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "start": "node --require source-map-support/register --require './appsignal.cjs' dist/server.js",
    "build": "tsc && echo '{\"type\":\"commonjs\"}' > dist/package.json && cp appsignal.cjs dist/appsignal.cjs && cd client && yarn install --production=false && yarn run build",
    "dev": "npm-run-all -p dev:*",
    "dev:server": "nodemon --exec tsx server.ts",
    "dev:worker": "nodemon --exec tsx worker.ts",
    "smoke:start": "node src/scripts/smoke/start.mjs",
    "smoke:check": "node src/scripts/smoke/check.mjs",
    "smoke:stop": "node src/scripts/smoke/stop.mjs",
    "test": "NODE_ENV=test jest --config=jest.config.mjs --no-coverage --maxWorkers=50%",
    "test:ci": "NODE_ENV=test jest --config=jest.config.mjs",
    "test:coverage": "NODE_ENV=test jest --config=jest.config.mjs --maxWorkers=50%",
    "watch": "NODE_ENV=test jest --no-coverage --verbose --watch --runInBand --notify --notifyMode always",
    "linter": "yarn eslint 'src/app/**/*.{js,ts,tsx}' 'src/config/**/*.{js,ts,tsx}' 'src/setup/**/*.{js,ts,tsx}'",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/plugin-transform-modules-commonjs": "^7.27.1",
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-typescript": "7.29.7",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "6.0.0",
    "@types/express": "5.0.6",
    "@types/jsonwebtoken": "9.0.10",
    "@types/morgan": "1.9.10",
    "@types/node": "24.13.2",
    "@typescript-eslint/eslint-plugin": "8.61.0",
    "@typescript-eslint/parser": "8.61.0",
    "@typescript-eslint/utils": "^8.58.0",
    "babel-jest": "^30.2.0",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-config-standard": "17.1.0",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jest": "29.15.2",
    "eslint-plugin-jest-dom": "5.5.0",
    "eslint-plugin-n": "18.1.0",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-promise": "7.3.0",
    "jest": "30.4.2",
    "jest-date-mock": "1.0.10",
    "mongodb-memory-server": "11.2.0",
    "npm-run-all2": "9.0.1",
    "prettier": "3.8.4",
    "supertest": "7.2.2",
    "typescript": "6.0.3"
  },
  "dependencies": {
    "@appsignal/nodejs": "^3.8.0",
    "@aws-sdk/client-s3": "^3.32.0",
    "@aws-sdk/s3-request-presigner": "^3.32.0",
    "@bull-board/api": "^8.0.0",
    "@bull-board/express": "^8.0.0",
    "@bull-board/ui": "^8.0.0",
    "@sentry/node": "^10.25.0",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "archiver": "8.0.0",
    "bcrypt": "6.0.0",
    "bullmq": "5.78.0",
    "cookie-parser": "1.4.7",
    "cors": "2.8.6",
    "debug": "4.4.3",
    "dotenv": "17.4.2",
    "esm-module-alias": "^2.2.1",
    "express": "5.2.1",
    "express-rate-limit": "8.5.2",
    "express-validator": "7.3.2",
    "fishery": "2.4.0",
    "helmet": "8.2.0",
    "http-errors": "2.0.1",
    "isomorphic-fetch": "3.0.0",
    "jsonwebtoken": "9.0.3",
    "lodash": "4.18.1",
    "module-alias": "2.3.4",
    "moment": "2.30.1",
    "moment-timezone": "0.6.2",
    "mongodb": "7.3.0",
    "mongoose": "9.7.0",
    "morgan": "1.11.0",
    "newrelic": "14.1.0",
    "node-notifier": "10.0.1",
    "nodemon": "3.1.14",
    "rate-limit-redis": "5.0.0",
    "rollbar": "3.1.0",
    "socket.io": "4.8.3",
    "source-map-support": "^0.5.21",
    "tsx": "4.22.4",
    "uuid": "14.0.0",
    "yarn": "1.22.22"
  },
  "_moduleAliases": {
    "@models": "./src/app/models",
    "@controllers": "./src/app/controllers",
    "@routes": "./src/app/routes",
    "@config": "./src/config",
    "@queries": "./src/app/queries",
    "@reports": "./src/app/reports",
    "@helpers": "./src/app/helpers",
    "@plugins": "./src/app/plugins",
    "@repositories": "./src/app/repositories"
  },
  "resolutions": {
    "lodash": "4.18.1",
    "@typescript-eslint/utils": "^8.58.0",
    "uuid": "14.0.0"
  }
}
